<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>오너스경영연구소 - 어드민 페이지</title>
    <link rel="stylesheet" href="admin.css" />
    <!-- Font Awesome 추가 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- CryptoJS 추가 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    <!-- Daum Postcode API -->
    <script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
    <!-- JSZip 추가 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <!-- SheetJS 추가 (엑셀 파일 처리용) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
  </head>
  <body class="admin-page">
    <!-- 햄버거 메뉴 버튼 (모바일용) -->
    <button id="sidebar-toggle" class="sidebar-toggle" aria-label="메뉴 열기">
      <svg width="32" height="32" viewBox="0 0 32 32"><rect y="6" width="32" height="4" rx="2"/><rect y="14" width="32" height="4" rx="2"/><rect y="22" width="32" height="4" rx="2"/></svg>
    </button>
    <!-- 로그인 폼: 항상 최상위에 위치 -->
    <div id="login-form">
      <div class="login-box">
        <div class="logo-area" style="text-align:center; margin-bottom:24px;">
          <img src="owners_logo.png" alt="로고" style="height: 100px;" />
        </div>
        <div class="input-group">
          <input type="email" id="admin-email" placeholder="이메일" autocomplete="username" />
          <input type="password" id="admin-password" placeholder="비밀번호" autocomplete="current-password" />
        </div>
        <button id="login-btn" type="button" onclick="login()">로그인</button>
      </div>
    </div>
    <div class="container admin-flex">
      <div class="sidebar" id="sidebar">
        <div class="sidebar-logo">
          <img src="owners_logo.png" alt="로고" style="height:80px;" />
        </div>
        <ul class="sidebar-menu">
          <li id="menu-managers" class="active">
            <span class="sidebar-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20"><circle cx="10" cy="7" r="4"/><rect x="3" y="13" width="14" height="5" rx="2"/></svg>
            </span>
            <span class="sidebar-text">담당자 관리</span>
          </li>
          <li id="menu-clients">
            <span class="sidebar-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20"><rect x="2" y="4" width="16" height="12" rx="2"/><rect x="5" y="7" width="10" height="2" rx="1"/><rect x="5" y="11" width="6" height="2" rx="1"/></svg>
            </span>
            <span class="sidebar-text">고객 정보 조회</span>
          </li>
          <li id="menu-manager-info">
            <span class="sidebar-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20"><circle cx="10" cy="10" r="8" fill="none" stroke="currentColor" stroke-width="2"/><path d="M10 6h0m0 8v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </span>
            <span class="sidebar-text">담당자 정보 조회</span>
          </li>
          <li id="menu-exam-schedule">
            <span class="sidebar-icon" aria-hidden="true">
              <i class="fas fa-calendar-alt"></i>
            </span>
            <span class="sidebar-text">자격시험 일정</span>
          </li>
        </ul>
        <button id="sidebar-logout-btn" onclick="logout()">로그아웃</button>
      </div>
      <div class="main-content" id="main-content">
        <!-- 관리자 콘텐츠 -->
        <div id="admin-content" style="display:none; margin-top: 50px;">
          <!-- 담당자 관리 영역 -->
          <div id="manager-section" class="manager-section">
            <h4>담당자 관리</h4>
            <p style="color: #666; font-size: 14px; margin-bottom: 16px;">
              담당자를 추가하고 기본 정보를 관리합니다. 상세 정보(개인정보, 연락처 등)는 <strong>담당자 정보 조회</strong> 페이지에서 수정할 수 있습니다.
            </p>
            
            <div class="manager-input-group">
              <input type="text" id="newManager" placeholder="새 담당자 이름" />
              <button id="addManagerBtn">추가</button>
            </div>

            <!-- 일괄 비밀번호 설정 버튼 (숨김 처리) -->
            <div style="display: none; text-align: center; margin: 20px 0; padding: 15px; background: #f8f9fa; border-radius: 8px; border-left: 4px solid #f39c12;">
              <p style="margin: 0 0 10px 0; color: #666; font-size: 14px;">
                <i class="fas fa-info-circle"></i> 기존 담당자들의 비밀번호를 일괄 설정합니다 (기본값: 0000)
              </p>
              <button id="bulkPasswordBtn" onclick="setupBulkPasswords()" style="background: #f39c12; color: white; padding: 10px 20px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer;">
                <i class="fas fa-users-cog"></i> 기존 담당자 비밀번호 일괄 설정
              </button>
            </div>
            
            <div id="managerList" class="manager-list"></div>
          </div>

          <!-- 담당자 정보 조회 영역 -->
          <div id="manager-info-section" style="display:none;">
            <h3 style="text-align: center;">담당자 정보 조회</h3>
            
            <!-- 엑셀 업로드 섹션 -->
            <div class="excel-upload-section" style="margin-bottom: 30px; padding: 20px; background: #f8f9fa; border-radius: 8px; border-left: 4px solid #3498db;">
              <h5 style="margin: 0 0 15px 0; color: #2c3e50; display: flex; align-items: center; gap: 8px;">
                <i class="fas fa-file-excel"></i>
                보험사 계정 정보 일괄 업로드
              </h5>
              <p style="margin: 0 0 15px 0; color: #666; font-size: 14px;">
                엑셀 파일에서 담당자명으로 매칭하여 가이아 아이디와 보험사 계정 정보를 자동으로 등록합니다.
              </p>
              <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                <input type="file" id="excelFileInput" accept=".xlsx,.xls" style="display: none;" onchange="handleExcelFile(event)" />
                <button onclick="document.getElementById('excelFileInput').click()" style="background: #3498db; color: white; padding: 10px 15px; border: none; border-radius: 5px; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                  <i class="fas fa-upload"></i>
                  엑셀 파일 선택
                </button>
                <span id="selectedFileName" style="color: #666; font-size: 14px;"></span>
                <button id="uploadExcelBtn" onclick="uploadExcelData()" style="background: #27ae60; color: white; padding: 10px 15px; border: none; border-radius: 5px; cursor: pointer; display: none;">
                  <i class="fas fa-save"></i>
                  업로드 실행
                </button>
              </div>
              <div id="uploadProgress" style="margin-top: 15px; display: none;">
                <div style="background: #ecf0f1; border-radius: 10px; overflow: hidden;">
                  <div id="progressBar" style="background: #3498db; height: 8px; width: 0%; transition: width 0.3s;"></div>
                </div>
                <div id="progressText" style="margin-top: 8px; color: #666; font-size: 14px;"></div>
              </div>
              <div id="uploadResult" style="margin-top: 15px; display: none;"></div>
            </div>
            
            <div class="search-area">
              <input type="text" id="managerSearchInput" placeholder="담당자명, 코드, 팀명으로 검색" />
              <button type="button" id="managerSearchResetBtn" class="search-reset-btn" aria-label="새로고침">
                <i class="fas fa-redo-alt"></i>
              </button>
            </div>
            <div id="managerCardList" class="card-list"></div>
            <div id="managerLoadMore" class="load-more-container" style="display: none;">
              <button id="managerLoadMoreBtn" class="load-more-btn">더보기 (<span id="managerRemainingCount">0</span>개 더)</button>
            </div>
          </div>

          <!-- 고객 정보 조회 영역 -->
          <div id="client-section" style="display:none;">
            <h3 style="text-align: center;">고객 정보 관리</h3>
            
            <!-- 마이그레이션 버튼 추가 -->
            <div style="text-align: center; margin-bottom: 20px;">
              <button id="migrateBtn" onclick="runMigration()" style="background: #e74c3c; color: white; padding: 10px 20px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer;">
                <i class="fas fa-sync-alt"></i> 주민등록번호 암호화 마이그레이션
              </button>
            </div>
            
            <div class="search-area">
              <input type="text" id="searchInput" placeholder="이름, 전화번호, 담담자명으로 검색" />
              <button type="button" id="searchResetBtn" class="search-reset-btn" aria-label="새로고침">
                <i class="fas fa-redo-alt"></i>
              </button>
            </div>
            <div id="cardList" class="card-list"></div>
            <div id="clientLoadMore" class="load-more-container" style="display: none;">
              <button id="clientLoadMoreBtn" class="load-more-btn">더보기 (<span id="clientRemainingCount">0</span>개 더)</button>
            </div>
            <!-- <button onclick="logout()">로그아웃</button> -->
          </div>
        </div>
      </div>
    </div>
    <div id="detailModal" class="modal" style="display: none">
      <div class="modal-content">
        <span class="close" id="closeModal">&times;</span>
        <div id="detailContent"></div>
      </div>
    </div>

    <script src="config.js"></script>
    <script type="module" src="admin.js"></script>
  </body>
</html>
 